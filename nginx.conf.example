##
## Nginx config for Heartstrings Attendance System (Laravel 11)
## Place this file at: /etc/nginx/sites-available/heartstrings
## Then: sudo ln -s /etc/nginx/sites-available/heartstrings /etc/nginx/sites-enabled/
##

server {
    listen 80;
    server_name your-domain.com www.your-domain.com;

    # Redirect all HTTP to HTTPS (required for GPS + Camera APIs)
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name your-domain.com www.your-domain.com;

    # ── SSL ───────────────────────────────────────────────────────────
    ssl_certificate     /etc/letsencrypt/live/your-domain.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/your-domain.com/privkey.pem;
    ssl_protocols       TLSv1.2 TLSv1.3;
    ssl_ciphers         ECDHE-RSA-AES256-GCM-SHA512:DHE-RSA-AES256-GCM-SHA512:ECDHE-RSA-AES256-GCM-SHA384;
    ssl_prefer_server_ciphers on;
    ssl_session_cache   shared:SSL:10m;

    # ── Root ──────────────────────────────────────────────────────────
    root /var/www/heartstrings/public;
    index index.php;

    # ── Security headers ──────────────────────────────────────────────
    add_header X-Frame-Options           "SAMEORIGIN"  always;
    add_header X-Content-Type-Options    "nosniff"     always;
    add_header X-XSS-Protection          "1; mode=block" always;
    add_header Referrer-Policy           "strict-origin-when-cross-origin" always;
    add_header Permissions-Policy        "geolocation=(self), camera=(self)" always;

    # ── Logging ───────────────────────────────────────────────────────
    access_log /var/log/nginx/heartstrings_access.log;
    error_log  /var/log/nginx/heartstrings_error.log;

    # ── Client limits ─────────────────────────────────────────────────
    client_max_body_size 10M;   # Allow up to 10MB (for base64 photos)

    # ── Static assets ─────────────────────────────────────────────────
    location ~* \.(jpg|jpeg|png|gif|ico|css|js|woff2|woff|ttf|svg|webp)$ {
        expires 1y;
        add_header Cache-Control "public, immutable";
        try_files $uri =404;
    }

    # ── Laravel front controller ──────────────────────────────────────
    location / {
        try_files $uri $uri/ /index.php?$query_string;
    }

    # ── PHP-FPM ───────────────────────────────────────────────────────
    location ~ \.php$ {
        fastcgi_pass   unix:/var/run/php/php8.3-fpm.sock;
        fastcgi_index  index.php;
        fastcgi_param  SCRIPT_FILENAME $realpath_root$fastcgi_script_name;
        include        fastcgi_params;
        fastcgi_read_timeout 300;
    }

    # ── Block sensitive files ─────────────────────────────────────────
    location ~ /\.(?!well-known).* {
        deny all;
    }
    location ~ /\.env {
        deny all;
    }
}
